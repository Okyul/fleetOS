# Copy to .env (gitignored) and fill in your credentials.

# --- HiveMQ Cloud (MQTT broker) ---
# Cluster Details + Access Management in the HiveMQ Cloud console.
HIVEMQ_HOST=your-cluster-id.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=fleetctl
HIVEMQ_PASSWORD=replace-me

# --- Cloudflare R2 (firmware hosting) ---
# Optional. If set, `fleetctl upload` and `fleetctl ota` work; otherwise you
# upload manually via the Cloudflare dashboard.
#
# Create at: Cloudflare R2 → Manage API Tokens → Create API token
#   - Permissions:  Object Read & Write
#   - Specify bucket: <your-bucket-name>
# Cloudflare shows you the access key + secret + endpoint URL after creation.
#
# R2_ACCOUNT_ID is the hex string in your S3 endpoint URL:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com/...
R2_ACCOUNT_ID=
R2_BUCKET=fleetos-firmware
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The pub-XXXXX.r2.dev URL Cloudflare gave you when you enabled "R2.dev
# subdomain" / Public Development URL on the bucket. No trailing slash.
R2_PUBLIC_URL_PREFIX=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
